# Frontend Environment Variables
# Copy this file to .env.local and customize as needed

# API Base URL - points to the backend server
# Local dev: /api (Vite proxy to localhost:3000)
# Production: https://mcp-monorepo-dx7n.vercel.app/api
VITE_API_URL=/api

# App Configuration
VITE_APP_NAME="Issue Tracker"
VITE_APP_VERSION="1.0.0"
